# Champions of NASCAR — environment variables
#
# Copy to `.env` and fill in real values: `cp .env.example .env`
# `.env` is gitignored — never commit real secrets.
#
# Every var below is validated at boot by src/lib/env.ts. A missing or malformed
# required var crashes the server on startup with a message naming the offender.
# `NEXT_PUBLIC_*` vars are exposed to the browser; everything else is server-only.

# --- Database (Postgres) --------------------------------------------------
# Pooled runtime connection used by the Prisma driver adapter (src/lib/db.ts).
# From Neon/Supabase: the pooled ("-pooler") connection string.
DATABASE_URL="postgresql://user:password@host:5432/nascar25?sslmode=require"
# Unpooled/direct connection for migrations (prisma.config.ts). Set ONLY when
# DATABASE_URL points at a pooler; otherwise leave unset and migrations reuse
# DATABASE_URL.
DIRECT_URL="postgresql://user:password@host:5432/nascar25?sslmode=require"

# --- Clerk (auth) ---------------------------------------------------------
# Clerk Dashboard → API Keys. Publishable key starts `pk_`, secret key `sk_`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"
# Clerk Dashboard → Webhooks → your endpoint → Signing Secret (NASCAR-011).
# Starts `whsec_`.
CLERK_WEBHOOK_SECRET="your-clerk-webhook-signing-secret"
# Routing — keep auth in-app instead of Clerk's hosted Account Portal.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- Resend (transactional email) -----------------------------------------
# Resend Dashboard → API Keys. Starts `re_`.
RESEND_API_KEY="your-resend-api-key"
# Verified sender on your Resend domain. Display name optional.
EMAIL_FROM="Champions of NASCAR <noreply@yourdomain.com>"
# Secret for signing email unsubscribe links (NASCAR-053). Authenticates the
# opt-out page with no login. Generate one: `openssl rand -hex 32`
EMAIL_UNSUBSCRIBE_SECRET="replace-with-a-long-random-string"

# --- Cron -----------------------------------------------------------------
# High-entropy shared secret the reminder cron route checks (NASCAR-052).
# Generate one: `openssl rand -hex 32`
CRON_SECRET="replace-with-a-long-random-string"

# --- App ------------------------------------------------------------------
# Public origin, used to build absolute links in emails. No trailing slash.
# Local: http://localhost:3000  •  Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
